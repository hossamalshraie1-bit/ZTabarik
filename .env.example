# ==========================================
# SUPABASE CONFIGURATION
# ==========================================
# Public variables exposed to the client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only variable (Secret Key — BYPASSES RLS)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Default Admin credentials
ADMIN_EMAIL=admin@studio.com
ADMIN_PASSWORD=YourPassword@2026

# ==========================================
# IMAGEKIT CONFIGURATION
# ==========================================
# Public variables exposed to the client
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-endpoint-id
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_your-public-key

# Server-only variable (Secret Key)
IMAGEKIT_PRIVATE_KEY=private_your-private-key
